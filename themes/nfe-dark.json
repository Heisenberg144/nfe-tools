{
  "name": "NFe Fiscal — NF-e Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0B0D14",
    "editor.foreground": "#E0E6ED",
    "editor.lineHighlightBackground": "#151826",
    "editor.selectionBackground": "#2A3B5F",
    "editorCursor.foreground": "#E0E6ED",
    "editorIndentGuide.background": "#151826",
    "editorIndentGuide.activeBackground": "#E0E6ED",
    "editorWhitespace.foreground": "#5C6370",
    "editor.selectionHighlightBackground": "#2A3B5F",
    "editor.lineHighlightBorder": "#151826"
  },
  "tokenColors": [
    {
      "name": "XML Declaration",
      "scope": ["meta.xml-declaration.nfe", "comment.block.xml.nfe"],
      "settings": { "foreground": "#5C6370", "fontStyle": "italic" }
    },
    {
      "name": "XML Comment",
      "scope": "comment.block.nfe",
      "settings": { "foreground": "#5C6370", "fontStyle": "italic" }
    },
    {
      "name": "Conteúdo valor",
      "scope": "string.value.nfe",
      "settings": { "foreground": "#E5C07B", "fontStyle": "bold" }
    },
    {
      "name": "Pontuação Genérica (< >)",
      "scope": "punctuation.definition.tag.nfe",
      "settings": { "foreground": "#5C6370" }
    },
    {
      "name": "Tag suporte (nome)",
      "scope": "support.type.tag.nfe",
      "settings": { "foreground": "#E06C75" }
    },
    {
      "name": "Tag genérica",
      "scope": ["entity.name.tag", "support.type.tag"],
      "settings": { "foreground": "#E06C75" }
    },
    {
      "name": "Atributo — nome",
      "scope": ["entity.other.attribute-name.nfe", "entity.other.attribute-name"],
      "settings": { "foreground": "#D19A66" }
    },
    {
      "name": "Atributo — valor",
