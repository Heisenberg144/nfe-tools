{
  "name": "NFe Fiscal Pro — NF-e Harmonic Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0D1117",
    "editor.foreground": "#C9D1D9",
    "editor.lineHighlightBackground": "#161B22",
    "editor.selectionBackground": "#23863644",
    "editorCursor.foreground": "#C9D1D9",
    "editorIndentGuide.background": "#161B22",
    "editorIndentGuide.activeBackground": "#C9D1D9",
    "editorWhitespace.foreground": "#484F58",
    "editor.selectionHighlightBackground": "#23863644",
    "editor.lineHighlightBorder": "#161B22"
  },
  "tokenColors": [
    {
      "name": "XML Declaration",
      "scope": ["meta.xml-declaration.nfe", "comment.block.xml.nfe"],
      "settings": { "foreground": "#8B949E", "fontStyle": "italic" }
    },
    {
      "name": "XML Comment",
      "scope": "comment.block.nfe",
      "settings": { "foreground": "#8B949E", "fontStyle": "italic" }
    },
    {
      "name": "Conteúdo valor",
      "scope": "string.value.nfe",
      "settings": { "foreground": "#F1E05A", "fontStyle": "bold" }
    },
    {
      "name": "Pontuação Genérica (< >)",
      "scope": "punctuation.definition.tag.nfe",
      "settings": { "foreground": "#484F58" }
    },
    {
      "name": "Tag suporte (nome)",
      "scope": "support.type.tag.nfe",
      "settings": { "foreground": "#FFAB70" }
    },
    {
      "name": "Tag genérica",
      "scope": ["entity.name.tag", "support.type.tag"],
      "settings": { "foreground": "#F78166" }
    },
    {
      "name": "Atributo — nome",
